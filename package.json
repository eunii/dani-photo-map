{
  "name": "dani-photo-map",
  "version": "0.1.0",
  "private": true,
  "description": "Dani Photo Map — local photo library organizer with map and groups.",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "clean": "node scripts/clean-dist.mjs",
    "dev:clean": "pnpm run clean && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.dani.photomap",
    "productName": "Dani Photo Map",
    "files": [
      "dist/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@heroui/react": "3.0.1",
    "exifr": "7.1.3",
    "maplibre-gl": "5.21.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.5",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "electron": "41.1.1",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  },
  "packageManager": "pnpm@10.33.0"
}
