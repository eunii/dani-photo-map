{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "types": [
      "vite/client"
    ],
    "noEmit": true
  },
  "include": [
    "index.html",
    "src/presentation/renderer/**/*.ts",
    "src/presentation/renderer/**/*.tsx",
    "src/shared/**/*.ts",
    "src/shared/**/*.tsx"
  ]
}
