{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": [
      "ES2023"
    ],
    "types": [
      "node"
    ],
    "noEmit": true
  },
  "include": [
    "electron.vite.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "src/domain/**/*.ts",
    "src/application/**/*.ts",
    "src/presentation/common/**/*.ts",
    "src/presentation/electron/**/*.ts",
    "src/infrastructure/**/*.ts",
    "src/shared/**/*.ts"
  ]
}
